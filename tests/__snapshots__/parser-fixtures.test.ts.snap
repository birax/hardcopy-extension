          "updatedAt": "2026-06-25T19:42:20.663108Z",
        },
      ],
      [
        {
          "attachments": [],
          "blocks": [
            {
              "text": "I'm baking a birthday cake for my dad this weekend. He likes coffee flavours.",
              "type": "text",
            },
          ],
          "createdAt": "2026-06-25T19:40:07.882064Z",
          "files": [],
