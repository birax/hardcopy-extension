{\\pard\\li360\\sb120\\sa60\\keepn\\b\\cf2\\f1\\fs20 Artifact: Tip calculator (tip-calculator, update, python, final version)\\par}
{\\pard\\li360\\sa120\\cbpat5\\cf1\\f1\\fs20 def tip(bill: float, percent: float = 15.0) -> float:\\line     return round(bill * percent / 100, 2)\\line \\line \\line if __name__ == "__main__":\\line     bill = float(input("Bill amount: "))\\line     diners = int(input("Diners: "))\\line     total = bill + tip(bill)\\line     print(f"Tip: \\{tip(bill)\\}")\\line     print(f"Each pays: \\{round(total / diners, 2)\\}")\\line \\par}
