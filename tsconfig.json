{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    ".wxt/wxt.d.ts",
    "src",
    "tests",
    "e2e",
    "playwright.config.ts",
    "wxt.config.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ]
}
